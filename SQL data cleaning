-- CREATING ORDER ITEMS TABLE--

CREATE TABLE order_items (
    order_id VARCHAR(50),
    order_item_id INT,
    product_id VARCHAR(50),
    seller_id VARCHAR(50),
    shipping_limit_date TEXT,
    price TEXT,
    freight_value TEXT
);

LOAD DATA INFILE 'path/to/orders.csv'
INTO TABLE order_items
FIELDS TERMINATED BY ','
ENCLOSED BY '"'
LINES TERMINATED BY '\n'
IGNORE 1 ROWS;

SELECT * FROM order_items;

CREATE TABLE order_items_backup AS SELECT * FROM order_items; 

ALTER TABLE order_items
ADD shipping_dt DATETIME;

UPDATE order_items
SET shipping_dt= STR_TO_DATE(shipping_limit_date,  '%m/%d/%Y %H:%i');

ALTER TABLE order_items
ADD price_num DECIMAL(10,2),
ADD freight_num DECIMAL(10,2);

UPDATE order_items
SET 
price_num = CAST(price AS DECIMAL(10,2)),
freight_num = CAST(freight_value AS DECIMAL(10,2));

ALTER TABLE order_items
DROP COLUMN shipping_limit_date,
DROP COLUMN price,
DROP COLUMN freight_value;

WITH duplicate_cte as(
SELECT *,
ROW_NUMBER() OVER(PARTITION BY order_id, order_item_id,product_id, seller_id, shipping_dt, price, freight_value) as row_num
FROM order_items
)
SELECT * from duplicate_cte
WHERE row_num>1;

SELECT order_id, order_item_id, COUNT(*)
FROM order_items
GROUP BY order_id, order_item_id
HAVING COUNT(*) >1;

SELECT 
COUNT(*) AS total_rows,
COUNT(DISTINCT order_id, order_item_id) AS unique_rows
FROM order_items;

-- CREATING ORDER PAYMENTS TABLE--

CREATE TABLE order_payments(
order_id VARCHAR(50),
payment_sequential INT,
payment_type VARCHAR(50),
payment_installments INT,
Payment_value DECIMAL(10,2)
);

LOAD DATA INFILE 'path/to/orders.csv'
INTO TABLE order_payments
FIELDS TERMINATED BY ','
ENCLOSED BY '"'
LINES TERMINATED BY '\n'
IGNORE 1 ROWS;



SELECT 
SUM(order_id IS NULL),
SUM(payment_sequential IS NULL),
SUM(payment_type IS NULL),
SUM(payment_installments IS NULL),
SUM(payment_value IS NULL)
FROM order_payments;

SELECT order_id, payment_sequential, COUNT(*) 
FROM order_payments
GROUP BY order_id, payment_sequential
HAVING COUNT(*)>1;

SELECT order_id, COUNT(*) AS payment_count
FROM order_payments
GROUP BY order_id
HAVING COUNT(*) > 1
LIMIT 10;
