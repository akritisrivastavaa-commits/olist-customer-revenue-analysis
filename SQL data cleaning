-- Creating new column to store date datatype--

DESCRIBE orders;

ALTER TABLE orders 
ADD purchase_dt DATETIME,
ADD approved_dt DATETIME,
ADD carrier_dt DATETIME,
ADD delivered_dt DATETIME,
ADD est_delivery_dt DATETIME;



UPDATE orders
SET purchase_dt = STR_TO_DATE(order_purchase_timestamp, '%m/%d/%Y %H:%i');

UPDATE orders
SET approved_dt = STR_TO_DATE(order_approved_at, '%m/%d/%Y %H:%i')
WHERE order_approved_at != '';

UPDATE orders
SET carrier_dt = STR_TO_DATE(order_delivered_carrier_date, '%m/%d/%Y %H:%i')
WHERE order_delivered_carrier_date != '';

UPDATE orders
SET delivered_dt = STR_TO_DATE(order_delivered_customer_date, '%m/%d/%Y %H:%i')
WHERE order_delivered_customer_date != '';

UPDATE orders
SET est_delivery_dt = STR_TO_DATE(order_estimated_delivery_date, '%m/%d/%Y %H:%i')
WHERE order_estimated_delivery_date != '';

ALTER TABLE orders
DROP COLUMN order_purchase_timestamp,
